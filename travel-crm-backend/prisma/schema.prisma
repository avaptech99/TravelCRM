// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  passwordHash     String
  role             String    @default("AGENT") // "ADMIN" or "AGENT"
  createdAt        DateTime  @default(now())
  
  assignedBookings Booking[] @relation("AssignedAgent")
  createdBookings  Booking[] @relation("CreatedBy")
  comments         Comment[]
}

model Booking {
  id                 String        @id @default(uuid())
  createdOn          DateTime      @default(now())
  
  createdByUserId    String?
  createdByUser      User?         @relation("CreatedBy", fields: [createdByUserId], references: [id])
  
  contactPerson      String
  contactNumber      String
  requirements       String?       @db.Text
  
  assignedToUserId   String?
  assignedToUser     User?         @relation("AssignedAgent", fields: [assignedToUserId], references: [id])
  
  status             String        @default("Pending") // "Pending", "Working", "Sent", "Booked"
  isConvertedToEDT   Boolean       @default(false)
  
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  
  comments           Comment[]
  travelers          Traveler[]
}

model Comment {
  id          String   @id @default(uuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id])
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  text        String   @db.Text
  createdAt   DateTime @default(now())
}

model Traveler {
  id            String   @id @default(uuid())
  bookingId     String
  booking       Booking  @relation(fields: [bookingId], references: [id])
  name          String
  phoneNumber   String?
  email         String?
  country       String?
  flightFrom    String?
  flightTo      String?
  departureTime String?
  arrivalTime   String?
  tripType            String?
  returnDate          String?
  returnDepartureTime String?
  returnArrivalTime   String?
  dob                 String?
  anniversary   String?
  isPrimary     Boolean  @default(false)
}
